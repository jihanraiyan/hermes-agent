#!/command/with-contenv sh
# Own credential files to the hermes runtime user on every boot.
#
# Credential files added to the /opt/data volume out-of-band (e.g. via
# `railway volume files upload`) land owned by the uploading process (root),
# not hermes. The stage2 first-boot chown is gated on top-level ownership and
# skips them on subsequent boots, so hermes can't rewrite them. That breaks:
#   - Google token refresh (google-workspace rewrites google_token.json on
#     access-token expiry -> EACCES when root-owned)
#   - file-based gh/git credentials the tool subprocess reads
#
# Runs as root (cont-init, before the s6 privilege drop). Targets only the
# known credential paths so it stays fast.
for p in \
    /opt/data/home/.hermes \
    /opt/data/home/.config \
    /opt/data/home/.gitconfig \
    /opt/data/home/.git-credentials \
    /opt/data/.hermes \
    /opt/data/google_token.json \
    /opt/data/google_client_secret.json \
    /opt/data/mcp-tokens
do
    # Refuse symlinked targets: these paths sit on the agent-writable volume,
    # and a root-run chown -R through a planted symlink is a privilege step-up.
    [ -L "$p" ] && continue
    [ -e "$p" ] && chown -R hermes:hermes "$p" 2>/dev/null || true
done
# chown never touches mode bits; uploaded files keep whatever mode the upload
# gave them until hermes first rewrites them (0600). Close that window for the
# OAuth token store here.
if [ -d /opt/data/mcp-tokens ] && [ ! -L /opt/data/mcp-tokens ]; then
    chmod 0700 /opt/data/mcp-tokens 2>/dev/null || true
    chmod -R go-rwx /opt/data/mcp-tokens 2>/dev/null || true
fi
echo "[cred-perms] ensured hermes owns credential paths on /opt/data"
